function getResultContent(score) {
  if (score <= 10) {
    return {
      title: "There may be meaningful opportunity being missed.",
      body: "Your responses suggest there may be real opportunity to strengthen underwriting influence, carrier access, case design support, and overall business positioning. EPG may be worth evaluating more closely.",
      accent: "text-amber-300",
    };
  }

  if (score <= 17) {
    return {
      title:
        "Your platform may be solid, but there are likely gaps worth pressure-testing.",
      body: "You appear to have some meaningful support in place, but there may still be opportunities to improve access, economics, advanced planning support, or overall producer value.",
      accent: "text-sky-300",
    };
  }

  return {
    title: "You appear to have a strong foundation in place.",
    body: "Your responses suggest strength in several key areas. Even so, EPG may still offer a useful benchmark if you want to compare your current model against other high-level producer platforms.",
    accent: "text-emerald-300",
  };
}

